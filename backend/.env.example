# Copy this file to .env and fill in your values

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-1.5-pro

# JWT Secret (change this to a random string in production)
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=sqlite:///./invoices.db

# Upload folder
UPLOAD_FOLDER=./uploads

# CORS — comma-separated list of allowed origins (no wildcards in production)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Admin bootstrap credentials (used by create_admin.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@hm.local
